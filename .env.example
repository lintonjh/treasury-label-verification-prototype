# Live provider configuration. Keep API keys server-side only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Live demo spend controls. These are app-side brakes, not a replacement for
# OpenAI project spend/rate limits in the dashboard.
OPENAI_DEMO_MAX_REQUESTS_PER_MINUTE=3
OPENAI_DEMO_MAX_REQUESTS_PER_HOUR=30
OPENAI_DEMO_MAX_REQUESTS_PER_DAY=100
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_REQUEST_TIMEOUT_MS=20000

# Optional server-side debugging for live OpenAI extraction.
# Set to debug to log provider request/response metadata. API keys, image bytes,
# and extracted label text are redacted.
LOG_LEVEL=info
